# WordPress / WooCommerce backend (cPanel). No trailing slash. Public — used for cart/checkout links.
NEXT_PUBLIC_WP_URL=https://sipmo.lk
# WooCommerce Store API base (public, read-only, no keys needed). Server-side only.
WOO_BASE_URL=https://sipmo.lk/wp-json/wc/store/v1
# Optional: comma-separated category slugs to show on the home (blank = all Woo categories).
NEXT_PUBLIC_HOME_CATEGORY_SLUGS=
