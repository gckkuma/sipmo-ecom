# WordPress / WooCommerce backend (cPanel). No trailing slash. Public — used for cart/checkout links.
# The store front lives on the apex (sipmo.lk / Vercel); WordPress+WooCommerce lives on www.
NEXT_PUBLIC_WP_URL=https://www.sipmo.lk
# WooCommerce Store API base (public, read-only, no keys needed). Server-side only.
WOO_BASE_URL=https://www.sipmo.lk/wp-json/wc/store/v1
# Whitelist of top-level category slugs to show (in this order). Blank = all categories.
# Real WooCommerce slugs drop the "&" (books-stationery, health-wellness, toys-games).
NEXT_PUBLIC_HOME_CATEGORY_SLUGS=tea-and-spices,clothing,gift-items,books-stationery,grocery,cosmetics,health-wellness,toys-games
